# Binweevils Private Server Rewrite
# Copy this file to .env when local config support is added.
# Do not commit real passwords, tokens, cookies, or VPS details.

# App
APP_NAME="Binweevils Private Server Rewrite"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Web server paths
PUBLIC_ROOT=game-full
LEGACY_GAME_ROOT=game-full

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bwps
DB_USER=root
DB_PASSWORD=

# Node/socket server
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
SOCKET_PORT=3001

# Optional launcher/browser settings
RUFFLE_ENABLED=false
ELECTRON_ENABLED=true

# Local development only
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_TEST_USERNAME=demo_weevil
