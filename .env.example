# Binweevils Private Server Rewrite
# Copy this file to .env for local overrides.
# Do not commit real passwords, cookies, VPS details, or production secrets.

# App
APP_NAME="Binweevils Private Server Rewrite"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Web server paths
PUBLIC_ROOT=game-full
LEGACY_GAME_ROOT=game-full

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bwps
DB_USER=root
DB_PASSWORD=

# Main Node runtime
# Defaults preserve the imported localhost setup.
NODE_BIND_HOST=
GAME_SOCKET_PORT=9339
WEB_SOCKET_PORT=2087

# REST compatibility shim
REST_HOST=
REST_PORT=1122
REST_GET_SERVER_RESPONSE=127-0-0-1:10843
REST_GET_SERVER_EX_RESPONSE=127-0-0-1:10842
REST_DEV_AUTH_A=dev-auth-a
REST_DEV_AUTH_B=dev-auth-b

# Older/uncertain WebSocket shim in server/server.js
LEGACY_SHIM_HOST=127.0.0.1
LEGACY_SHIM_PORT=10843

# Optional launcher/browser settings
RUFFLE_ENABLED=false
ELECTRON_ENABLED=true

# Local development only
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_TEST_USERNAME=demo_weevil
